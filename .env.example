# LaunchOps Stack Environment Variables
# Copy this to .env and fill in your values.
# The install.sh script auto-generates secure passwords if .env doesn't exist.

# Database credentials (auto-generated by install.sh)
DB_PASSWORD=change_me_to_a_secure_password
DB_ROOT_PASSWORD=change_me_to_a_secure_root_password

# Vaultwarden admin token (auto-generated by install.sh)
VAULT_ADMIN_TOKEN=change_me_to_a_secure_token

# Stripe API Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Domain (for production deployment with SSL)
DOMAIN=yourdomain.com

# Email SMTP (for Mautic)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
