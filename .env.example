# =============================================================================
#  LaunchOps Founder Edition — Environment Variables
#  Copy this file to .env and fill in your values.
#  The install.sh script auto-generates secure passwords if .env doesn't exist.
#
#  WARNING: Never commit .env to version control.
# =============================================================================

# ── Database credentials (auto-generated by install.sh) ──────────────────────
DB_PASSWORD=change_me_to_a_secure_password
DB_ROOT_PASSWORD=change_me_to_a_secure_root_password

# ── Vaultwarden admin token (auto-generated by install.sh) ───────────────────
VAULT_ADMIN_TOKEN=change_me_to_a_secure_token

# ── SuiteCRM (CRM / Sales Pipeline) ──────────────────────────────────────────
# SuiteCRM uses the shared DB_PASSWORD above.
# On first run, visit http://localhost:8081 and complete the setup wizard:
#   DB Host:     db
#   DB Name:     suitecrm
#   DB User:     wpuser
#   DB Password: (value of DB_PASSWORD above)
# After setup, generate an API token in Admin → OAuth2 Clients and set below:
SUITECRM_URL=http://localhost:8081
SUITECRM_TOKEN=

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Required for LaunchOps AI agents (dynexecutiv, support_agent, etc.)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Stripe API Keys (get from https://dashboard.stripe.com/apikeys) ───────────
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# ── Domain (for production deployment with SSL) ───────────────────────────────
DOMAIN=yourdomain.com

# ── Email SMTP (for Mautic email automation) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
