# LaunchOps Founder Edition — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ══════════════════════════════════════════════════════════════
# LLM PROVIDERS (at least one REQUIRED for Founder Edition)
# ══════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-your-openai-key
OPENAI_API_BASE=
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ══════════════════════════════════════════════════════════════
# STRIPE (Payment Processing)
# ══════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key

# ══════════════════════════════════════════════════════════════
# INFRASTRUCTURE
# ══════════════════════════════════════════════════════════════
DOMAIN=yourdomain.com
ADMIN_EMAIL=founder@yourdomain.com
DATA_DIR=/opt/launchops

# ══════════════════════════════════════════════════════════════
# WORDPRESS
# ══════════════════════════════════════════════════════════════
WORDPRESS_DB_PASSWORD=change_this_password
WORDPRESS_DB_ROOT_PASSWORD=change_this_password
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_this_password

# ══════════════════════════════════════════════════════════════
# MAUTIC (Marketing Automation)
# ══════════════════════════════════════════════════════════════
MAUTIC_DB_PASSWORD=change_this_password
MAUTIC_DB_ROOT_PASSWORD=change_this_password
MAUTIC_ADMIN_USER=admin
MAUTIC_ADMIN_PASSWORD=change_this_password

# ══════════════════════════════════════════════════════════════
# NEXTCLOUD (File Storage)
# ══════════════════════════════════════════════════════════════
NEXTCLOUD_DB_PASSWORD=change_this_password
NEXTCLOUD_DB_ROOT_PASSWORD=change_this_password
NEXTCLOUD_ADMIN_PASSWORD=change_this_password

# ══════════════════════════════════════════════════════════════
# CHATWOOT (Customer Support)
# ══════════════════════════════════════════════════════════════
CHATWOOT_DB_PASSWORD=change_this_password
CHATWOOT_SECRET_KEY=change_this_to_a_long_random_string

# ══════════════════════════════════════════════════════════════
# MATOMO (Analytics)
# ══════════════════════════════════════════════════════════════
MATOMO_DB_PASSWORD=change_this_password
MATOMO_DB_ROOT_PASSWORD=change_this_password

# ══════════════════════════════════════════════════════════════
# BITWARDEN (Password Manager)
# ══════════════════════════════════════════════════════════════
BITWARDEN_ADMIN_TOKEN=change_this_strong_token

# ══════════════════════════════════════════════════════════════
# GITHUB (Repo Automation)
# ══════════════════════════════════════════════════════════════
GITHUB_TOKEN=ghp_your-github-token

# ══════════════════════════════════════════════════════════════
# CREDENTIAL VAULT ENCRYPTION
# ══════════════════════════════════════════════════════════════
VAULT_KEY=
# Auto-generated on first run if empty
